---
import { readGallerySections } from '../../lib/content';

export function getStaticPaths() {
  const sections = readGallerySections();
  const paths: { params: { slug: string }; props: { title: string; file: string } }[] = [];

  for (const section of sections) {
    for (const pdf of section.pdfs) {
      const title = pdf.subtitle ? `${pdf.title} — ${pdf.subtitle}` : pdf.title;
      const slug = [pdf.title, pdf.subtitle].filter(Boolean).join(' ')
        .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      paths.push({ params: { slug }, props: { title, file: pdf.file } });
    }
  }
  return paths;
}

const { title, file } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #525659;
      color: #fff;
    }
    .pdf-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      height: 56px;
      background: #1a1a1a;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .pdf-header-btn {
      background: none;
      border: none;
      color: #fff;
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.75rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-family: inherit;
      transition: opacity 0.3s ease;
    }
    .pdf-header-btn:hover { opacity: 0.7; }
    .pdf-header-btn svg { width: 20px; height: 20px; }
    .pdf-title {
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 1px;
      overflow: hidden;
      text-overflow: ellipsis;
      text-align: center;
      white-space: nowrap;
      flex: 1;
      margin: 0 16px;
    }
    .pdf-page-count {
      font-size: 0.75rem;
      letter-spacing: 1px;
      color: rgba(255, 255, 255, 0.5);
    }
    .pdf-pages {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 16px;
    }
    .pdf-pages canvas {
      display: block;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      max-width: 100%;
      height: auto;
    }
    .pdf-loading {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.85rem;
      letter-spacing: 1px;
    }
    @media (max-width: 768px) {
      .pdf-title { font-size: 0.75rem; }
    }
  </style>
</head>
<body>
  <div class="pdf-header">
    <button class="pdf-header-btn" id="back-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back
    </button>
    <span class="pdf-title">{title}</span>
    <span class="pdf-page-count" id="page-count"></span>
  </div>
  <div class="pdf-loading" id="pdf-loading">Loading...</div>
  <div class="pdf-pages" id="pdf-pages" style="display:none;"></div>

  <script is:inline define:vars={{ file }}>
    document.getElementById('back-btn').addEventListener('click', function() {
      if (history.length > 1) history.back();
      else window.location.href = '/gallery';
    });

    import('https://unpkg.com/pdfjs-dist@4.10.38/build/pdf.min.mjs').then(async function(pdfjsLib) {
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://unpkg.com/pdfjs-dist@4.10.38/build/pdf.worker.min.mjs';
      var doc = await pdfjsLib.getDocument(file).promise;
      var dpr = window.devicePixelRatio || 1;
      var maxWidth = Math.min(window.innerWidth - 32, 1200);
      var pagesEl = document.getElementById('pdf-pages');
      var loadingEl = document.getElementById('pdf-loading');
      var pageCountEl = document.getElementById('page-count');

      loadingEl.style.display = 'none';
      pagesEl.style.display = '';
      pageCountEl.textContent = doc.numPages + ' page' + (doc.numPages > 1 ? 's' : '');

      for (var i = 1; i <= doc.numPages; i++) {
        var page = await doc.getPage(i);
        var unscaled = page.getViewport({ scale: 1 });
        var scale = maxWidth / unscaled.width;
        var viewport = page.getViewport({ scale: scale * dpr });
        var canvas = document.createElement('canvas');
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        canvas.style.width = Math.round(viewport.width / dpr) + 'px';
        canvas.style.height = Math.round(viewport.height / dpr) + 'px';
        var ctx = canvas.getContext('2d');
        await page.render({ canvasContext: ctx, viewport: viewport }).promise;
        pagesEl.appendChild(canvas);
      }
    });
  </script>
</body>
</html>
