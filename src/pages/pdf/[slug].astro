---
import { readGallerySections, slugForPdf } from '../../lib/content';

export function getStaticPaths() {
  const sections = readGallerySections();
  const paths: { params: { slug: string }; props: { title: string; subtitle: string; file: string } }[] = [];

  for (const section of sections) {
    for (const pdf of section.pdfs) {
      const slug = slugForPdf(pdf.title, pdf.file);
      paths.push({ params: { slug }, props: { title: pdf.title, subtitle: pdf.subtitle, file: pdf.file } });
    }
  }
  return paths;
}

const { title, subtitle, file } = Astro.props;
const docTitle = subtitle ? `${title} — ${subtitle}` : title;
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{docTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="modulepreload" href="https://unpkg.com/pdfjs-dist@4.10.38/build/pdf.min.mjs">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #525659;
      color: #fff;
    }
    .pdf-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      height: 56px;
      background: #1a1a1a;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .pdf-header-btn {
      background: none;
      border: none;
      color: #fff;
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.75rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      font-family: inherit;
      transition: opacity 0.3s ease;
    }
    .pdf-header-btn:hover { opacity: 0.7; }
    .pdf-header-btn svg { width: 20px; height: 20px; }
    .pdf-title {
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 1px;
      overflow: hidden;
      text-overflow: ellipsis;
      text-align: center;
      white-space: nowrap;
      flex: 1;
      margin: 0 16px;
    }
    .pdf-header-right {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }
    .pdf-header-sep {
      width: 1px;
      height: 14px;
      background: rgba(255, 255, 255, 0.18);
    }
    .pdf-page-count {
      font-size: 0.7rem;
      letter-spacing: 1px;
      color: rgba(255, 255, 255, 0.45);
      white-space: nowrap;
    }
    .pdf-zoom {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .pdf-zoom-level {
      font-size: 0.7rem;
      letter-spacing: 1px;
      color: rgba(255, 255, 255, 0.6);
      min-width: 38px;
      text-align: center;
    }
    .pdf-zoom-btn {
      background: none;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 4px;
      color: #fff;
      cursor: pointer;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s ease, border-color 0.2s ease;
    }
    .pdf-zoom-btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); }
    .pdf-zoom-btn:disabled { opacity: 0.3; cursor: default; }
    .pdf-zoom-btn svg { width: 14px; height: 14px; }
    .pdf-layout {
      width: 100%;
    }
    .pdf-pages {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 16px;
    }
    .pdf-pages canvas {
      display: block;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      max-width: 100%;
      height: auto;
    }
    .pdf-loading {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
    }
    .pdf-spinner {
      width: 28px;
      height: 28px;
      border: 2px solid rgba(255, 255, 255, 0.15);
      border-top-color: rgba(255, 255, 255, 0.65);
      border-radius: 50%;
      animation: pdf-spin 0.7s linear infinite;
    }
    @keyframes pdf-spin {
      to { transform: rotate(360deg); }
    }
    .pdf-info {
      position: fixed;
      top: 72px;
      right: 16px;
      width: 320px;
      padding: 22px 22px 24px;
      background: #1e2021;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      max-height: calc(100vh - 88px);
      overflow-y: auto;
      z-index: 5;
      opacity: 0;
      transition: opacity 0.35s ease, max-height 0.3s ease;
    }
    .pdf-info.visible { opacity: 1; }
    .pdf-info.zoomed-hidden { opacity: 0; pointer-events: none; }
    .pdf-info.force-mobile {
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      width: auto;
      max-height: 60vh;
      max-height: 60dvh;
      padding: 0;
      padding-bottom: env(safe-area-inset-bottom, 0px);
      border-radius: 0;
      border: none;
      background: rgba(82, 86, 89, 0.72);
      backdrop-filter: blur(20px) brightness(2.0);
      -webkit-backdrop-filter: blur(20px) brightness(2.0);
      z-index: 20;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .pdf-info.force-mobile.collapsed {
      max-height: calc(44px + env(safe-area-inset-bottom, 0px));
    }
    .pdf-info.force-mobile .pdf-info-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 12px 16px;
      background: none;
      border: none;
      color: #000;
      font-family: inherit;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      cursor: pointer;
      flex-shrink: 0;
    }
    .pdf-info.force-mobile .pdf-info-chevron { width: 16px; height: 16px; color: #000; }
    .pdf-info.force-mobile.collapsed .pdf-info-chevron { transform: rotate(180deg); }
    .pdf-info.force-mobile .pdf-info-panel { padding: 4px 16px 20px; overflow-y: auto; flex: 1; }
    .pdf-info.force-mobile .pdf-info-label { display: none; }
    .pdf-info.force-mobile .pdf-info-desc { color: #000; }
    .pdf-info-toggle {
      display: none;
    }
    .pdf-info-label {
      display: block;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.45);
      margin-bottom: 14px;
    }
    .pdf-info-desc {
      font-size: 0.88rem;
      line-height: 1.65;
      color: rgba(255, 255, 255, 0.88);
    }
    @media (max-width: 1024px) {
      .pdf-header { height: 44px; padding: 0 14px; }
      .pdf-header-btn { font-size: 0.65rem; padding: 6px; }
      .pdf-header-btn svg { width: 16px; height: 16px; }
      .pdf-title { font-size: 0.7rem; }
      .pdf-zoom { display: none; }
      .pdf-header-sep { display: none; }
      .pdf-info {
        position: fixed;
        top: auto;
        bottom: 0;
        left: 0;
        right: 0;
        width: auto;
        margin: 0;
        padding: 0;
        padding-bottom: env(safe-area-inset-bottom, 0px);
        border-radius: 0;
        border: none;
        background: rgba(82, 86, 89, 0.72);
        backdrop-filter: blur(20px) brightness(2.0);
        -webkit-backdrop-filter: blur(20px) brightness(2.0);
        z-index: 20;
        display: flex;
        flex-direction: column;
        max-height: 60vh;
        max-height: 60dvh;
        overflow: hidden;
        transition: opacity 0.35s ease, max-height 0.3s ease;
      }
      .pdf-info.collapsed {
        max-height: calc(44px + env(safe-area-inset-bottom, 0px));
      }
      .pdf-info-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding: 12px 16px;
        background: none;
        border: none;
        color: #000;
        font-family: inherit;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        cursor: pointer;
        flex-shrink: 0;
      }
      .pdf-info-chevron {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
      }
      .pdf-info.collapsed .pdf-info-chevron { transform: rotate(180deg); }
      .pdf-info-panel {
        padding: 0 16px 20px;
        overflow-y: auto;
        flex: 1;
      }
      .pdf-info-panel .pdf-info-label { display: none; }
      .pdf-info-desc { color: #000; }
    }
  </style>
</head>
<body>
  <div class="pdf-header">
    <button class="pdf-header-btn" id="back-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back
    </button>
    <span class="pdf-title">{title}</span>
    <div class="pdf-header-right">
      <span class="pdf-page-count" id="page-count"></span>
      <span class="pdf-header-sep"></span>
      <div class="pdf-zoom" id="pdf-zoom">
        <button class="pdf-zoom-btn" id="zoom-out" aria-label="Zoom out" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <span class="pdf-zoom-level" id="zoom-level">100%</span>
        <button class="pdf-zoom-btn" id="zoom-in" aria-label="Zoom in">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
      </div>
    </div>
  </div>
  <div class="pdf-layout">
    <div class="pdf-main">
      <div class="pdf-loading" id="pdf-loading"><div class="pdf-spinner"></div></div>
      <div class="pdf-pages" id="pdf-pages" style="display:none;"></div>
    </div>
  </div>
  {subtitle && (
    <aside class="pdf-info" id="pdf-info">
      <button class="pdf-info-toggle" id="pdf-info-toggle" type="button" aria-expanded="true" aria-controls="pdf-info-panel">
        <span>About this project</span>
        <svg class="pdf-info-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="18 15 12 9 6 15"/>
        </svg>
      </button>
      <div class="pdf-info-panel" id="pdf-info-panel">
        <span class="pdf-info-label">About this project</span>
        <p class="pdf-info-desc">{subtitle}</p>
      </div>
    </aside>
  )}

  <script is:inline define:vars={{ file }}>
    document.getElementById('back-btn').addEventListener('click', function() {
      if (history.length > 1) history.back();
      else window.location.href = '/gallery';
    });

    var infoEl = document.getElementById('pdf-info');
    var infoToggleEl = document.getElementById('pdf-info-toggle');
    var mainEl = document.querySelector('.pdf-main');

    function updateScrollPadding() {
      if (!mainEl || !infoEl) return;
      var isMobile = window.innerWidth <= 1024 || infoEl.classList.contains('force-mobile');
      if (!isMobile) { mainEl.style.paddingBottom = ''; return; }
      mainEl.style.paddingBottom = infoEl.offsetHeight + 'px';
    }

    if (typeof ResizeObserver !== 'undefined' && infoEl) {
      new ResizeObserver(updateScrollPadding).observe(infoEl);
    }
    window.addEventListener('resize', updateScrollPadding);

    if (infoToggleEl) {
      infoToggleEl.setAttribute('aria-expanded', 'true');
      infoToggleEl.addEventListener('click', function() {
        var isCollapsed = infoEl.classList.toggle('collapsed');
        infoToggleEl.setAttribute('aria-expanded', !isCollapsed);
        setTimeout(updateScrollPadding, 320);
      });
    }

    var ZOOM_STEPS = [0.75, 1, 1.25, 1.5, 2];
    var zoomIndex = 1; // start at 100%
    var pdfDoc = null;
    var baseMaxWidth = 0;
    var pagesEl = document.getElementById('pdf-pages');
    var loadingEl = document.getElementById('pdf-loading');
    var zoomOutBtn = document.getElementById('zoom-out');
    var zoomInBtn = document.getElementById('zoom-in');
    var zoomLevelEl = document.getElementById('zoom-level');

    function updateZoomButtons() {
      zoomOutBtn.disabled = zoomIndex === 0;
      zoomInBtn.disabled = zoomIndex === ZOOM_STEPS.length - 1;
      zoomLevelEl.textContent = Math.round(ZOOM_STEPS[zoomIndex] * 100) + '%';
    }

    // Sidebar: right edge of centered PDF vs left edge of sidebar (right:16 width:320)
    function pdfOverlapsSidebar(pdfWidth) {
      var sidebarLeft = window.innerWidth - 336;
      var pdfRight = (window.innerWidth + pdfWidth) / 2;
      return pdfRight > sidebarLeft;
    }

    function positionSidebar(isZoomChange) {
      if (!infoEl || window.innerWidth <= 1024) return;
      var pdfWidth = baseMaxWidth * ZOOM_STEPS[zoomIndex];
      var overlaps = pdfOverlapsSidebar(pdfWidth);
      if (!isZoomChange) {
        if (overlaps) {
          infoEl.classList.add('force-mobile');
        } else {
          infoEl.classList.remove('force-mobile');
          if (mainEl) mainEl.style.paddingBottom = '';
        }
        infoEl.classList.add('visible');
      } else {
        if (!infoEl.classList.contains('force-mobile')) {
          if (overlaps) {
            infoEl.classList.add('zoomed-hidden');
          } else {
            infoEl.classList.remove('zoomed-hidden');
          }
        }
      }
    }

    async function renderPages(doc, maxW) {
      var dpr = window.devicePixelRatio || 1;
      var quality = Math.max(dpr, 2);
      pagesEl.innerHTML = '';
      var tasks = [];
      for (var i = 1; i <= doc.numPages; i++) {
        tasks.push((function(pageNum) {
          return doc.getPage(pageNum).then(function(page) {
            var unscaled = page.getViewport({ scale: 1 });
            var scale = maxW / unscaled.width;
            var viewport = page.getViewport({ scale: scale * quality });
            var canvas = document.createElement('canvas');
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            canvas.style.width = Math.round(viewport.width / quality) + 'px';
            canvas.style.height = Math.round(viewport.height / quality) + 'px';
            return page.render({ canvasContext: canvas.getContext('2d'), viewport: viewport }).promise
              .then(function() { return { pageNum: pageNum, canvas: canvas }; });
          });
        })(i));
      }
      var results = await Promise.all(tasks);
      results.sort(function(a, b) { return a.pageNum - b.pageNum; });
      results.forEach(function(r) { pagesEl.appendChild(r.canvas); });
    }

    if (zoomOutBtn) {
      zoomOutBtn.addEventListener('click', async function() {
        if (zoomIndex > 0) {
          var ratio = window.scrollY / document.documentElement.scrollHeight;
          zoomIndex--;
          updateZoomButtons();
          await renderPages(pdfDoc, baseMaxWidth * ZOOM_STEPS[zoomIndex]);
          positionSidebar(true);
          window.scrollTo(0, ratio * document.documentElement.scrollHeight);
        }
      });
      zoomInBtn.addEventListener('click', async function() {
        if (zoomIndex < ZOOM_STEPS.length - 1) {
          var ratio = window.scrollY / document.documentElement.scrollHeight;
          zoomIndex++;
          updateZoomButtons();
          await renderPages(pdfDoc, baseMaxWidth * ZOOM_STEPS[zoomIndex]);
          positionSidebar(true);
          window.scrollTo(0, ratio * document.documentElement.scrollHeight);
        }
      });
    }

    import('https://unpkg.com/pdfjs-dist@4.10.38/build/pdf.min.mjs').then(async function(pdfjsLib) {
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://unpkg.com/pdfjs-dist@4.10.38/build/pdf.worker.min.mjs';
      pdfDoc = await pdfjsLib.getDocument(file).promise;

      loadingEl.style.display = 'none';
      pagesEl.style.display = '';
      document.getElementById('page-count').textContent = pdfDoc.numPages + ' page' + (pdfDoc.numPages > 1 ? 's' : '');

      baseMaxWidth = Math.min(pagesEl.clientWidth - 32, 1200);
      updateZoomButtons();
      await renderPages(pdfDoc, baseMaxWidth);
      positionSidebar(false);
      if (infoEl && window.innerWidth <= 1024) infoEl.classList.add('visible');
      updateScrollPadding();
    });
  </script>
</body>
</html>
