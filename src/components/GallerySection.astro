---
import ImageGrid from './ImageGrid.astro';
import PdfCard from './PdfCard.astro';

interface Pdf {
  title: string;
  subtitle: string;
  file: string;
}

interface Props {
  id: string;
  title: string;
  folder: string;
  description: string;
  pdfs?: Pdf[];
  youtubeUrl?: string;
}

const { id, title, folder, description, pdfs, youtubeUrl } = Astro.props;
---
<section class={youtubeUrl ? 'animations-section' : 'gallery-section'} id={id}>
  <div class="container">
    <div class={youtubeUrl ? 'fade-in' : 'gallery-header fade-in'} style={youtubeUrl ? 'text-align:center;' : ''}>
      <h2 class={youtubeUrl ? 'animations-title' : ''}>{title}</h2>
      <div class={youtubeUrl ? 'animations-desc' : ''} set:html={description} />
    </div>

    <ImageGrid folder={folder} alt={title} />

    {pdfs && pdfs.length > 0 && (
      <div class="pdf-section fade-in">
        <h3 class="pdf-section-title">View More</h3>
        <div class="pdf-grid">
          {pdfs.map(pdf => <PdfCard title={pdf.title} subtitle={pdf.subtitle} file={pdf.file} />)}
        </div>
      </div>
    )}

    {youtubeUrl && (
      <div style="text-align:center; margin-top:16px;" class="fade-in">
        <a href={youtubeUrl} target="_blank" rel="noopener" class="animation-link">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          Watch on YouTube
        </a>
      </div>
    )}
  </div>
</section>
