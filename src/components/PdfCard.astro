---
import { slugForPdf } from '../lib/content';
interface Props {
  title: string;
  subtitle: string;
  file: string;
}
const { title, subtitle, file } = Astro.props;
const slug = slugForPdf(title, file);
---
<a href={`/pdf/${slug}`} class="pdf-card">
  <div class="pdf-card-info">
    <h4>{title}</h4>
    {subtitle && <p>{subtitle}</p>}
  </div>
  <svg class="pdf-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
    <polyline points="14 2 14 8 20 8"/>
    <line x1="16" y1="13" x2="8" y2="13"/>
    <line x1="16" y1="17" x2="8" y2="17"/>
    <polyline points="10 9 9 9 8 9"/>
  </svg>
</a>
